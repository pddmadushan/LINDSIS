<UserControl x:Class="CMSXtream.Pages.DataEntry.PaymetType"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="25" />
            <RowDefinition Height="5" />
            <RowDefinition Height="25" />
            <RowDefinition Height="10" />
            <RowDefinition Height="20" />
        </Grid.RowDefinitions>
        <Label Grid.Row="1"  Grid.Column="0" Content="Monthly Fee" />
        <TextBox Grid.Column="1" Name="txtAmount" IsEnabled="False" TextAlignment="Right" PreviewTextInput="NumberValidationTextBox"  MaxLength="10" Margin="0,10,4.6,0" Grid.RowSpan="2"  />
        <RadioButton x:Name="chkClsFee" Content="" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" ClickMode="Press" GroupName="fee"/>

        <Label Grid.Row="3"  Grid.Column="0" Content="Course Fee" />
        <TextBox Grid.Row="3" Grid.Column="1" Name="txtCauseFee" IsEnabled="False" TextAlignment="Right" PreviewTextInput="NumberValidationTextBox"  MaxLength="10" Margin="0,0,4.6,10" Grid.RowSpan="2" />
        <RadioButton x:Name="chkCouseFee"  Content="" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" ClickMode="Press" GroupName="fee" />

        <Button x:Name="btnSave"  Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Content="Save" ToolTip="Save Record" Padding="0,0" BorderThickness="1"  Click="btnSave_Click" Margin="223,0.4,0,0.4" HorizontalAlignment="Left" Width="43" >
        </Button>

    </Grid>
</UserControl>
