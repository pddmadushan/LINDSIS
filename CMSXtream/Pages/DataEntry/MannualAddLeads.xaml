<UserControl x:Class="CMSXtream.Pages.DataEntry.MannualAddLeads"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             xmlns:mycls="clr-namespace:CMSXtream.Pages.DataEntry"
             mc:Ignorable="d">

    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin=" 0,0,0,0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Label Content="User : " VerticalAlignment="Center" Grid.Column="0" Grid.Row="0"/>
        <ComboBox x:Name="cmbUsers" Height="25" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left"/>
        <Label Content="Add Date :" VerticalAlignment="Center" Grid.Column="0" Grid.Row="2"/>
        <DatePicker x:Name="dtpAddDate" Width="120" Height="25" HorizontalAlignment="Left" Grid.Column="1" Grid.Row="2" SelectedDate="{x:Static sys:DateTime.Now}">
            <DatePicker.Resources>
                <Style TargetType="DatePickerTextBox">
                    <Setter Property="IsReadOnly" Value="True"/>
                </Style>
            </DatePicker.Resources>
        </DatePicker>
        <Label Content="Add Name :" VerticalAlignment="Center" Grid.Column="0" Grid.Row="3" Visibility="Hidden"/>
        <TextBox x:Name="txtbxAddName" Width="300" Height="25" Grid.Column="1" Grid.Row="3" Text="" HorizontalAlignment="Left" Visibility="Hidden" />
        <Label Content="Campaign : " VerticalAlignment="Center" Grid.Column="0" Grid.Row="1"/>
        <ComboBox x:Name="cmbCampaigns" Height="25" Grid.Column="1" Grid.Row="1"   />
        <mui:ModernButton x:Name="btnRefresh" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Refresh " Height="26" VerticalAlignment="Center" HorizontalAlignment="Left" Width="22" Click="btnRefresh_Click" Grid.Column="2" Grid.Row="1" />
        <DataGrid x:Name="grdManualLead" Grid.Row="4"  Width="Auto" Height="370" Grid.ColumnSpan="3" AutoGenerateColumns="False" CanUserAddRows="False"   CanUserDeleteRows="False"  VirtualizingStackPanel.IsVirtualizing="False" MinRowHeight="30" IsReadOnly="False" VerticalAlignment="Top" LoadingRow="grdManualLead_LoadingRow"  d:ItemsSource="{d:SampleData}" HorizontalAlignment="Left" RowHeaderWidth="35" PreviewKeyDown="DataGrid_PreviewKeyDown" >
            <DataGrid.Resources>
                <mycls:DoubleToVisaulConverter x:Key="DoubleToVis" />
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="St.ID" Width="300" Binding="{Binding CMP_STD_ID}" Visibility="Hidden"/>
                <DataGridTextColumn Header="Mobile" Width="100" Binding="{Binding STD_TELEPHONE,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  />
                <DataGridTextColumn Header="First Name" Width="250" Binding="{Binding STD_FIRST_NAME,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Last Name" Width="300" Binding="{Binding STD_LAST_NAME}" Visibility="Hidden"/>
                <DataGridTextColumn Header="Comment" Width="300" Binding="{Binding USER_COMMENT}" Visibility="Hidden"/>
                <DataGridTemplateColumn x:Name="addLable"  Width="37" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <mui:ModernButton x:Name="btnAddLable" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="24" EllipseStrokeThickness="1" ToolTip="Show Lable"  Click="btnAddLable_Click" Visibility="{Binding Path=CMP_STD_ID,Converter={StaticResource DoubleToVis}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <mui:ModernButton x:Name="btnDeleteLead" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Unassign student in this row"  Click="btnDeleteLead_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn x:Name="INV" Visibility="Visible" Width="25">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding INV}" Value="0">
                                    <Setter Property="Background" Value="White" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding INV}" Value="1">
                                    <Setter Property="Background" Value="Red" />
                                    <Setter Property="ToolTip" Value="Invalid Mobile Number"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="btnSave" Content="Save"  ToolTip="Save Records " Height="25" VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Click="btnSave_Click" Grid.Column="1" Grid.Row="2"  Background="AliceBlue" Grid.ColumnSpan="2" Margin="267,0,0,0" />
        <Button x:Name="btnClose" Content="Close"  ToolTip="Close " Height="26" VerticalAlignment="Center" HorizontalAlignment="Left" Width="100" Grid.Column="1" Grid.Row="2"  Background="AliceBlue" Click="btnClose_Click" Margin="267,0,0,0" Grid.ColumnSpan="2" />

    </Grid>
</UserControl>
