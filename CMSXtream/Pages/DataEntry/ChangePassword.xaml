<UserControl x:Class="CMSXtream.Pages.DataEntry.ChangePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" Height="250" Width="325" >
    <Grid >
        <Label Content="User Name" HorizontalAlignment="Left" Margin="26,20,0,0" VerticalAlignment="Top"/>
        <Label Content="PassWord" HorizontalAlignment="Left" Margin="26,45,0,0" VerticalAlignment="Top"/>
        <Label Content="Confirm Password " HorizontalAlignment="Left" Margin="26,73,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.598,-2.517"/>
        <PasswordBox x:Name="txtPassWord" HorizontalAlignment="Left" MaxLength="100" Margin="150,42,0,0" VerticalAlignment="Top" Width="148"/>
        <PasswordBox x:Name="txtConfirmPassWord" HorizontalAlignment="Left" MaxLength="100" Margin="150,69,0,0" VerticalAlignment="Top" RenderTransformOrigin="0,-0.364" Width="148"/>
        <TextBox x:Name="txtUserId" HorizontalAlignment="Left" MaxLength="20" Height="23" Margin="150,14,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="148"/>

        <TextBox  x:Name="txtInsentivePtg" Grid.Row="0" PreviewTextInput="NumberValidationTextBox" TextAlignment="Right" MaxLength="2" Margin="150,120,110.8,106.6"  >
            <TextBox.Text >
                <Binding Path="SelectedItem.CLS_FEE" ElementName= "cmbClsGroup" Mode="OneWay" UpdateSourceTrigger="PropertyChanged"></Binding>
            </TextBox.Text>
        </TextBox>
        <CheckBox x:Name="chkActive" Content="Active" HorizontalAlignment="Left" Height="19" Margin="150,96,0,0" VerticalAlignment="Top" Width="74" Checked="chkActive_Checked" Unchecked="chkActive_Unchecked"/>
        <CheckBox x:Name="chkAdmin" Content="Admin" HorizontalAlignment="Left" Height="19" Margin="224,96,0,0" VerticalAlignment="Top" Width="74" Checked="chkAdmin_Checked" Unchecked="chkAdmin_Unchecked" />
        <Button x:Name="btnSave"  ToolTip="Save Record" Click="btnSave_Click" Padding="0,0" BorderThickness="1"  Margin="234,160,26.8,31.6" >
            <Image Name="imgSave" Source ="pack://application:,,,/Image/ImgBtnSave.png" Width="60" Height="58" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" RenderTransformOrigin="0.503,1.333"   >
            </Image>
        </Button>
        <Label Content="Incentives ptg" HorizontalAlignment="Left" Margin="26,120,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.598,-2.517"/>
    </Grid>
</UserControl>
