<UserControl x:Class="CMSXtream.Pages.DataEntry.AssignStudentToAdmins"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:mycls="clr-namespace:CMSXtream.Pages.DataEntry"
             xmlns:local="clr-namespace:CMSXtream.Handlers"
             mc:Ignorable="d" xmlns:mui="http://firstfloorsoftware.com/ModernUI">

    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:IntOfTwoColumnToVisibilityConverter x:Key="IntOfTwoColumnToVisibilityConverter"/>
            <local:IntValueToVisibilityConverter x:Key="IntValueToVisibilityConverter"/>
            <local:PendingDaysVisibleConverter x:Key="PendingDayZeroTextVisible"/>
            <local:PendingDaysColorVisibleConverter x:Key="PendingDaysGreaterThan3"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"  />
            <ColumnDefinition Width="10"  />
            <ColumnDefinition Width="Auto"  />
        </Grid.ColumnDefinitions>
        <!--seperate grid into 2 parts-->

        <GroupBox x:Name="grpBoxCampaingData" HorizontalAlignment="Left" MaxHeight="800"  Margin="10,30,0,0" VerticalAlignment="Top" Width="430" Grid.ColumnSpan="2" >
            <GroupBox.Header>

                <Grid Height="30" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <!--grid headet colmn title-->
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label FontSize="12">Search</Label>
                    <TextBox x:Name="campainTextSearch" FontSize="12" Grid.Column="1" Margin="0,0,0,2" TextChanged="campainTextSearch_TextChanged" />
                    <Label Name="lblCampaingCount" FontSize="12" Grid.Column="3" Foreground="#FF0010FF" Margin="5,0,0,2"  />
                    <mui:ModernButton x:Name="btnRefresh"  Grid.Column="5" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseStrokeThickness="1" ToolTip="Refresh data" Click="btnRefresh_Click"    HorizontalAlignment="Center" Margin="0,1,0,2" Width="26" RenderTransformOrigin="-0.423,0.536"   />
                </Grid>
            </GroupBox.Header>

            <DataGrid x:Name="gridCmpNames"  HorizontalAlignment="Left" VerticalAlignment="Top" Width="400"  AutoGenerateColumns="False"  CanUserAddRows="False"   CanUserDeleteRows="False"  VirtualizingStackPanel.IsVirtualizing="False" MinRowHeight="30" IsReadOnly="True" Background="White" LoadingRow="DataGrid_LoadingRow" RowHeaderWidth="35">
                <DataGrid.Resources>
                    <!---CHANGE GRId TEXT ALIGNMENT OF BOTH HEADER AND CELL-->
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <!---grid columns-->
                    <DataGridTemplateColumn Width="30" Header="CK" SortMemberPath="chkCmpMark.Check.value" >
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkCmpMarkAll" Checked="chkCmpMarkAll_Checked" Unchecked="chkCmpMarkAll_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>

                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkCmpMark" Checked="chkCmpMark_Checked" Unchecked="chkCmpMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="50" Header="CMP_ID" Binding="{Binding Path=CMP_ID}" Visibility="Hidden"/>
                    <DataGridTextColumn Width="*" Header="Camapaings" Binding="{Binding Path=CMP_DES}" />
                </DataGrid.Columns  >
            </DataGrid>
        </GroupBox>
        <!---2d grp std data-->
        <GroupBox x:Name="grpBoxStdData" Grid.Column="3" HorizontalAlignment="Left" MaxHeight="800"  Margin="10,0,0,0" VerticalAlignment="Top" Width="Auto">
            <GroupBox.Header>
                <StackPanel >
                    <!--StackPanel ADD more than 1 rows in group headr-->
                    <Grid Height="50" Margin="0,0,0,0">
                        <!--1ST ROWS IN GROUP HEADER-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"  />
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="9"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="330"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label x:Name="lblLeadSearch" FontSize="12" Margin="0,0,4,0">Search</Label>
                        <TextBox x:Name="studentTextSearch" FontSize="12" TextChanged="studentTextSearch_TextChanged" RenderTransformOrigin="0.5,1.2" Grid.Column="1" HorizontalAlignment="Right" Width="200" Height="30"  />
                        <Label x:Name="lblDataCount" Grid.Column="3" Content="" HorizontalAlignment="left"  VerticalAlignment="Center" Width="auto" RenderTransformOrigin="-3.171,-1.441" HorizontalContentAlignment="Left" Height="25"/>
                        <GroupBox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3"  HorizontalAlignment="Left">
                            <GroupBox.Header>
                                <Grid>
                                    <Label Content="Use Date Filters to View Assigned Leads" FontSize="10" VerticalAlignment="Top"/>
                                </Grid>
                            </GroupBox.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>
                                <DatePicker x:Name="dtpFromdate" VerticalAlignment="top" Height="25" Grid.Column="0" Width="100"/>
                                <Label Content="To" Grid.Column="1" HorizontalAlignment="Center"/>
                                <DatePicker x:Name="dtpTodate" VerticalAlignment="top" Height="25" Grid.Column="2" Width="100" HorizontalAlignment="Left"/>
                                <Button x:Name="btnGetAssignStd" Grid.Column="4" Content="Get Assigned Leads" HorizontalAlignment="Center" Height="30" VerticalAlignment="Center" Width="170" Click="btnGetAssignStd_Click" Background="AliceBlue" ToolTip="Get Assign leads for selected User" />
                            </Grid>
                        </GroupBox>
                    </Grid>
                    <!--grid header-->
                    <Grid Height="50">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="57" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="28.073" />
                            <ColumnDefinition Width="61.927"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbSelectUser" Grid.Column="1" HorizontalAlignment="Center" Height="30" VerticalAlignment="Center" Width="200"/>
                        <mui:ModernButton x:Name="btnSearchUnassignStudent" IconData="{Binding Data, Source={StaticResource ImgSearch}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Load Unassign Student" Click="btnSearchUnassignStudent_Click" Height="25" VerticalAlignment="Top" HorizontalAlignment="Center" Width="26" Margin="0,10,0,0" />
                        <Button x:Name="btnAssignStudent" Grid.Column="3" Content="Assign" HorizontalAlignment="Left" Height="30" VerticalAlignment="Center" Width="90" Click="btnAssignStudent_Click" Background="AliceBlue" ToolTip="Assign leads to seleted user" Grid.ColumnSpan="2" />
                        <Button x:Name="btnUnAssignStudent" Grid.Column="3" Content="Unassign" HorizontalAlignment="Center" Height="30" VerticalAlignment="Center" Width="90" Click="btnUnAssignStudent_Click" Background="AliceBlue" ToolTip="UnAssign leads from seleted user" Visibility="Collapsed" Grid.ColumnSpan="2" />
                        <Button x:Name="btnGetMyLeads" Grid.Column="2" Content="View User's Leads" HorizontalAlignment="Center" Height="30" VerticalAlignment="Center" Width="140" Click="btnGetMyLeads_Click" Background="AliceBlue" ToolTip="Get Assign student for selected User" />
                        <Button x:Name="btnTransferLeads" Grid.Column="6" Content="Transfer Lead" HorizontalAlignment="Center" Height="30" VerticalAlignment="Center" Width="130" Click="btnTransferLeads_Click" Background="AliceBlue" ToolTip="Transfer Selected Leads from current User to another Users " Visibility="Visible" />
                        <mui:ModernButton x:Name="btnBulkDeleteLead" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delete Selected Leads"   Grid.Column="7" HorizontalAlignment="Right" Click="btnBulkDeleteLead_Click"/>
                        <mui:ModernButton x:Name="btnViewDeletedLeads"   Grid.Column="8" ToolTip="View deleted leads in past 7 days" Padding="0,0" BorderThickness="1"  Click="btnViewDeletedLeads_Click"   IconData="{Binding Data, Source={StaticResource ImgVeiwReport}}"  EllipseDiameter="25" EllipseStrokeThickness="1"/>
                    </Grid>
                </StackPanel>
            </GroupBox.Header>

            <DataGrid x:Name="grdStdData" HorizontalAlignment="Left" MaxHeight="650" Width="900" VerticalAlignment="Top"  AutoGenerateColumns="False"  CanUserAddRows="False"   CanUserDeleteRows="False"  VirtualizingStackPanel.IsVirtualizing="False" MinRowHeight="30" IsReadOnly="True" Background="White" d:ItemsSource="{d:SampleData}" LoadingRow="DataGrid_LoadingRow" RowHeaderWidth="35">
                <DataGrid.Resources>
                    <mycls:DoubleToVisaulConverter x:Key="DoubleToVis" />
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="CheckBox" Width="30" Header="CK" SortMemberPath="chkCmpMark.Check.value" >
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkStdMarkAll" Checked="chkStdMarkAll_Checked" Unchecked="chkStdMarkAll_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate >
                                <CheckBox Name="chkStdMark" Checked="chkStdMark_Checked" Unchecked="chkStdMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="50" Header="ID" Binding="{Binding Path=CMP_STD_ID}" Visibility="Hidden" />
                    <DataGridTemplateColumn x:Name="clmHistory" Width="140" Header="Name">
                        <DataGridTemplateColumn.CellTemplate >
                            <DataTemplate >
                                <StackPanel Orientation="Vertical" >
                                    <TextBlock x:Name="textBlock1" Text="{Binding STD_FULL_NAME }"  TextWrapping="Wrap" />
                                    <mui:ModernButton x:Name="btnHistory" IconData="{Binding Data, Source={StaticResource ImgHistory}}" EllipseDiameter="24" EllipseStrokeThickness="1" ToolTip="Show history" IsManipulationEnabled="True" Click="btnHistory_Click" 
                                                     Margin="0,10,90,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="90" Header="Mobile" Binding="{Binding Path=STD_TELEPHONE}" />
                    <DataGridTextColumn Width="130" Header="Up Date" Binding="{Binding Path=UPLOADED_DATE}"/>
                    <DataGridTemplateColumn x:Name="userInfo" Header="Info " Width="200"  >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock x:Name="textBlock1" Text="{Binding bandscore }"  />
                                    <TextBlock x:Name="textBlock2"  Text="{Binding exam_type}" />
                                    <TextBlock x:Name="textBlock3"  Text="{Binding when_do_you_want}"  />
                                    <TextBlock x:Name="textBlock4"  Text="{Binding your_english_knowledge}"  />
                                    <TextBlock x:Name="textBlock5"  Text="{Binding your_ielts_knowledge}"  />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn  Width="45" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="CellBorder" Padding="1" >
                                    <StackPanel Orientation="Horizontal">
                                        <mui:ModernButton x:Name="btnAddLable" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record"  Click="btnAddLable_Click" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn x:Name="clmTransferLead" Width="35" Visibility="Hidden" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical">
                                    <!---Add student button 1-->
                                    <mui:ModernButton x:Name="btnAddStudent" IconData="{Binding Data, Source={StaticResource ImgAttendance}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Add selected Lead as Student" Click="btnAddStudent_Click" >
                                        <mui:ModernButton.Visibility>
                                            <Binding  Path="ISNOT_CLS_STD" Converter="{StaticResource IntValueToVisibilityConverter}"/>
                                        </mui:ModernButton.Visibility>
                                    </mui:ModernButton>
                                    <!---Edit student button-->
                                    <mui:ModernButton x:Name="btnEdit" IconData="{Binding Data, Source={StaticResource ImgLeadOpen}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnEdit_Click">
                                        <mui:ModernButton.Visibility>
                                            <Binding  Path="IS_CLS_STD" Converter="{StaticResource IntValueToVisibilityConverter}"/>
                                        </mui:ModernButton.Visibility>
                                    </mui:ModernButton>
                                    <mui:ModernButton x:Name="btnAssignRowStudent" IconData="{Binding Data, Source={StaticResource ImgAddStudent}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Assign student in this row" Click="btnAssignRowStudent_Click"/>
                                    <mui:ModernButton x:Name="btnUnassignRowStudent" IconData="{Binding Data, Source={StaticResource ImgHistory}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Unassign student in this row"  Click="btnUnassignRowStudent_Click" />
                                    <mui:ModernButton x:Name="btnDeleteLeadStudent" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delete Lead in this row"  Click="btnDeleteLead_Click" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="38">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <mui:ModernButton x:Name="btnWarning" IconData="{Binding Data, Source={StaticResource ImgAlert}}"  EllipseDiameter="25" EllipseStrokeThickness="0">
                                    <mui:ModernButton.IconWidth>20</mui:ModernButton.IconWidth>
                                    <mui:ModernButton.IconHeight>20</mui:ModernButton.IconHeight>
                                    <mui:ModernButton.Visibility>
                                        <MultiBinding Converter="{StaticResource IntOfTwoColumnToVisibilityConverter}">
                                            <Binding Path="INCOMPLETED_STD_DATA" />
                                            <Binding Path="INCOMPLETED_STD_CLS_REGISTRATION" />
                                        </MultiBinding>
                                    </mui:ModernButton.Visibility>
                                </mui:ModernButton>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding INCOMPLETED_STD_CLS_REGISTRATION}" Value="0">
                                        <Setter Property="Background" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding INCOMPLETED_STD_CLS_REGISTRATION}" Value="1" >
                                        <Setter Property="Background" Value="Yellow" />
                                        <Setter Property ="ToolTip" Value="Student is not registered yet"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding INCOMPLETED_STD_DATA}" Value="1">
                                        <Setter Property="Background" Value="Red" />
                                        <Setter Property="ToolTip" Value="Incomplete Student Data (Gender,Class......)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="pndDays" Width="30" Header="ST" >
                        <DataGridTextColumn.CellStyle >
                            <Style TargetType="DataGridCell" >
                                <Style.Setters>
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Path=PENDING_DAYS}" Visibility="{Binding PENDING_DAYS, Converter={StaticResource PendingDayZeroTextVisible}}" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold">
                                                    <TextBlock.ToolTip>
                                                        <ToolTip>
                                                            <TextBlock>
                                        <Run Text="{Binding PENDING_DAYS}"/>
                                        <Run Text=" Days pending from "/>
                                        <Run Text="{Binding ASSIGNED_DATE}"/>
                                                            </TextBlock>
                                                        </ToolTip>
                                                    </TextBlock.ToolTip>
                                                 </TextBlock>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style.Setters>

                                <Style.Triggers >
                                    <DataTrigger Binding="{Binding PENDING_DAYS}" Value="0" >
                                        <Setter Property="Background" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PENDING_DAYS}" Value="1">
                                        <Setter Property="Background" Value="#FF04B835" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PENDING_DAYS}" Value="2">
                                        <Setter Property="Background" Value="Yellow" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PENDING_DAYS}" Value="3">
                                        <Setter Property="Background" Value="Orange" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PENDING_DAYS, Converter={StaticResource PendingDaysGreaterThan3}}" Value="True">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>