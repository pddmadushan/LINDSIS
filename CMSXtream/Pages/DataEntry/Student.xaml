                                <TextBox x:Name="txtTotPaid" Grid.Row="1" Grid.Column="2" Margin="0.4,0.2,10.2,4.2" IsEnabled="False" FontWeight="Bold"  />
                                <TextBox x:Name="txtTotBalance" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="129.4,0.2,9.8,4.2" IsEnabled="False" FontWeight="Bold" />
                                <mui:ModernButton x:Name="btnIntroducerPaymentHistory" Grid.Row="1" Grid.Column="5" IconData="{Binding Data, Source={StaticResource ImgPayment}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Payment History" Click="BtnIntroducerPaymentHistory_Click" Grid.ColumnSpan="2" Margin="0.2,0.2,127,0.2"/>
                                <DataGrid Grid.Row="2" Grid.ColumnSpan="7" Name="grdintroduced" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0" Height="190" >
