                                        <DataGridTextColumn Header="Name" Binding="{Binding Path=STD_INITIALS}" IsReadOnly="True" Width="110" Visibility="Hidden"  />
                                        <DataGridTextColumn Header="Tag" Binding="{Binding Path=STD_SURNAME}" IsReadOnly="True" Width="100" Visibility="Hidden" />
                                        <DataGridTextColumn Header="Full Name" Binding="{Binding Path=STD_FULL_NAME}" IsReadOnly="True" Width="150" />
                                        <DataGridTextColumn Header="Total Reward Amt" Binding="{Binding Path=TOTAL_REWORD}" IsReadOnly="True"  Width="170" />
                                        <DataGridTextColumn Header="Eligibe Amt" Binding="{Binding Path=TOTAL_ELIGIBLE}" IsReadOnly="True"  Width="170" />
                                        <DataGridTemplateColumn Width="40" >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <mui:ModernButton x:Name="btnInduecEdit" IconData="{Binding Data, Source={StaticResource ImgEdit}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnInduesEdit_Click"/>
