<UserControl xmlns:Control="clr-namespace:CMSXtream.Control"  x:Class="CMSXtream.Pages.DataEntry.Student"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI" 
             xmlns:mycls="clr-namespace:CMSXtream.Pages.DataEntry" 
             xmlns:txtMask="clr-namespace:CMSXtream.Control" 
             mc:Ignorable="d" d:DesignWidth="1100" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <GroupBox x:Name="grpBoxStudent"  Grid.Row="1" Grid.Column="0"   >
            <GroupBox.Header>
                <mui:ModernButton x:Name="btnSendSMS" IconData="{Binding Data, Source={StaticResource ImgSMS}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Send SMS" Click="btnSendSMS_Click" />
            </GroupBox.Header>
            <Grid HorizontalAlignment="Left" Margin="0,10,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition MinWidth="250" Width="250*"/>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition MinWidth="150" Width="270*"/>
                    <ColumnDefinition Width="173*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="45" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" MinHeight="72" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Name="lblClassId" Visibility="Hidden"/>
                <Label Content="Class Group:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                <ComboBox x:Name="cmbClsGroup" Grid.Row="0" SelectionChanged="cmbClsGroup_SelectionChanged" Style="{DynamicResource ComboBoxFlatStyle}" TabIndex="0" Margin="0,0,21,0" Grid.Column="1" />
                <Label Content="Fee:" Grid.Row="0" Grid.Column="2" Margin="22,0,164,4" FontWeight="Bold" Grid.ColumnSpan="2"/>
                <Label x:Name="lblClassStatus" Content="" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" FontSize="11" FontWeight="Bold" />
                <TextBox  x:Name="txtClsFee" Grid.Row="0" Grid.Column="3" PreviewTextInput="NumberValidationTextBox" TextAlignment="Right" MaxLength="6" TabIndex="1" Margin="136,0,5,0"   >
                    <TextBox.Text >
                        <Binding Path="SelectedItem.CLS_FEE" ElementName= "cmbClsGroup" Mode="OneWay" UpdateSourceTrigger="PropertyChanged"></Binding>
                    </TextBox.Text>
                </TextBox>
                <Button x:Name="cmdPayType" Content="Course" Grid.Column="2" HorizontalAlignment="Left"   VerticalAlignment="Top" Width="79" Margin="57,0,0,0" Height="25" Grid.ColumnSpan="2" Click="Button_Click" FontSize="11"  />
                <Label Content="Week for the Reminder:" Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" FontWeight="Bold" />
                <TextBox  x:Name="txtLastWeek" Grid.Row="0" Grid.Column="5"  PreviewTextInput="NumberValidationTextBox" TextAlignment="Right" MaxLength="6" TabIndex="1" Margin="55.667,0,95.333,0"  />

                <Label  Content="Full Name:" Grid.Row="3" Grid.Column="0"/>
                <TextBox x:Name="txtInitials" Grid.Row="4" Grid.Column="1" Margin="0,0,125,4" MaxLength="100" MaxWidth="500" TabIndex="3"  />

                <Label  Content="Student ID:" Grid.Row="2" Grid.Column="2" Margin="22,0,131,4"  FontWeight="Bold" Grid.ColumnSpan="2"/>
                <Label   x:Name="lblStudentId"  Content="[New Student]" Grid.Row="2" Grid.Column="3" Margin="101,0,10,29" Grid.RowSpan="2"  />
                <Grid Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Label x:Name="lblViewIntroducer"  Content="View Introducer" Grid.Row="0" Grid.Column="3"  FontWeight="Bold" Margin="29,0,0,0"/>
                    <mui:ModernButton x:Name="btnveiwStudent" Grid.Row="0" Grid.Column="4" IconData="{Binding Data, Source={StaticResource ImgStudents}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="View Introducer"  Click="btnveiwStudent_Click" />
                    <Label x:Name="lblStudentIntroduced"  Content="[Introducer]" Grid.Row="0" Grid.Column="1" />
                    <Label x:Name="lblStudentName"  Content="" Grid.Row="0" Grid.Column="2" />
                    <mui:ModernButton x:Name="btnAddIntroducer" Grid.Row="0" Grid.Column="0" IconData="{Binding Data, Source={StaticResource ImgAddStudent}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Add Introducer" Click="btnAddIntroducer_Click" RenderTransformOrigin="-5.481,0.5"  />
                    <Label x:Name="lblUserName"  Content="" Grid.Row="0" Grid.Column="4" FontWeight="Bold" Margin="52,0,-238,0" Foreground="#FF1D14CB" FontStyle="Italic" />
                </Grid>
                <Label Content="C-Name/Tag:" Grid.Row="4" Grid.Column="0"/>
                <TextBox x:Name="txtSurName" Grid.Row="4" Grid.Column="1" Margin="130,0,0,4" MaxLength="100"  MaxWidth="500" TabIndex="4" />

                <Label x:Name="txtTempClas"  Content="Temp. Prfd:" Grid.Row="2" Grid.Column="0"  />
                <ComboBox x:Name="cmbPrefClsGroup" Grid.Row="2" Grid.Column="1" Style="{DynamicResource ComboBoxFlatStyle}" TabIndex="0" Margin="0,0,28,5" />

                <mui:ModernButton x:Name="btnChangeClass" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right"   ToolTip="Click to make this class permanent"  Click="btnChangeClass_Click" IconData="{Binding Data, Source={StaticResource ImgAttendance}}" Margin="0,0,0,4" ></mui:ModernButton>

                <TextBox  x:Name="txtFullName" Grid.Row="3" Grid.Column="1" Margin="0,0,0,4" MaxLength="250" MaxWidth="500" TabIndex="2" MouseDoubleClick="txtFullName_MouseDoubleClick" >
                </TextBox>

                <Label Content="Gender:" Grid.Row="8" Grid.Column="0"/>
                <Grid   Grid.Row="8" Grid.Column="1" Margin = "0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <RadioButton x:Name="rbtnMale"  Grid.Row="0" Grid.Column="0" Content="Male" GroupName="a" UseLayoutRounding="False" TabIndex="7"  />
                    <RadioButton x:Name="rbtnFemale" Grid.Row="0" Grid.Column="1" Content="Female" GroupName="a">
                    </RadioButton>
                </Grid>

                <Label Content="Birthday:" Grid.Row="6" Grid.Column="0" Visibility="Hidden" Margin="0,0,0,30" Grid.RowSpan="2"/>
                <DatePicker x:Name="dtpBirthday" Grid.Row="6" Grid.Column="1" Margin="0,0,0,30" Visibility="Hidden" Grid.RowSpan="2" >
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="IsReadOnly" Value="True"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <Label Content="Join Date:" Grid.Row="12" Grid.Column="0"/>
                <DatePicker  x:Name="dtpJoinDate" Grid.Row="12" Grid.Column="1" Margin="0,0,0,4"  SelectedDate="{x:Static sys:DateTime.Now }" TabIndex="11"  >
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox" >
                            <Setter Property="IsReadOnly" Value="True"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <Label Content="NIC Number:" Grid.Row="9" Grid.Column="0"/>
                <TextBox x:Name="txtNICNumber" Grid.Row="9" Grid.Column="1" Margin="0,0,0,4" MaxLength="15" MaxWidth="500"  CharacterCasing="Upper" TabIndex="8" />

                <Label Content="Telephone no:" Grid.Row="5" Grid.Column="0" Margin="0,0,4,0"/>
                <txtMask:MaskedTextBox x:Name="txtTelephoneNumber" Grid.Row="5" Grid.Column="1" Margin="0,0,125,4"  MaxWidth="500"  PreviewTextInput="NumberValidationTextBox" 
                       TabIndex="5"   />
                <txtMask:MaskedTextBox x:Name="txtTelephoneNumber2" Grid.Row="5" Grid.Column="1" Margin="130,0,0,4"  MaxWidth="500"  PreviewTextInput="NumberValidationTextBox" 
                       TabIndex="5"   />

                <Label Content="E-Mail:" Grid.Row="10" Grid.Column="0"/>
                <TextBox x:Name="txtEmail" Grid.Row="10" Grid.Column="1" Margin="0,0,0,4" MaxWidth="500" TabIndex="9" />

                <Label Content="Address:" Grid.Row="11" Grid.Column="0"/>
                <TextBox x:Name="txtAdders" Grid.Row="11" Grid.Column="1" Margin="0,0,0,4" MaxLength="250"  TextWrapping="Wrap" AcceptsReturn="True" MaxWidth="500" TabIndex="10" />

                <Label Content="Comment:" Grid.Row="7" Grid.Column="0"/>
                <TextBox  x:Name="txtComment"  Grid.Row="7" Grid.Column="1"  MaxLength="250" TextWrapping="Wrap" AcceptsReturn="True" MaxWidth="500" TabIndex="6" />

                <Label Content="Note:" Grid.Row="13" Grid.Column="0"/>
                <TextBox  x:Name="txtNote"  Grid.Row="13" Grid.Column="1"  MaxLength="250" TextWrapping="Wrap" AcceptsReturn="True" MaxWidth="500" Background="#FFFFF300" TabIndex="12" />

                <Label Content="Labels:" Grid.Row="14" Grid.Column="0" Margin="0,5,0,0">
                </Label>
                <Label   x:Name="lblLableCount"  Content="" Grid.Row="14" Grid.Column="0" HorizontalAlignment="Right" Width="35" Margin="0,7,0,0" FontSize="11" FontWeight="Bold" />
                <mui:ModernButton x:Name="btnAddLable" Grid.Row="14" Grid.Column="1" HorizontalAlignment="Left"  IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Define Lable" Width="27" Click="btnAddLable_Click" />
                <StackPanel  x:Name="skPanelLable"  Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="32,7,0.333,10" >
                </StackPanel>
                <Label Content="Status:" Grid.Row="15" Grid.Column="0" Margin="0,5,0,0"/>
                <RadioButton  x:Name="chkActive" Grid.Row="15" Grid.Column="1" Margin="0,0,0,39" IsChecked="True"  GroupName="chk" Content="Attending" Checked="chkActive_Checked" Unchecked="chkActive_Unchecked" TabIndex="13" />
                <RadioButton  x:Name="chkInactive" Grid.Row="15" Grid.Column="1" Margin="0,21,0,19" GroupName="chk" Content="Temporarily Inactive" />
                <RadioButton  x:Name="chkInactivePernt" Grid.Row="15" Grid.Column="1" Margin="0,41,0,0"  GroupName="chk"  Content="Permanently Inactive"/>
                <ComboBox x:Name="cmbInactiveReason" Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="4" Style="{DynamicResource ComboBoxFlatStyle}" Height="25" Margin="141,34,44,14" />
                <mui:ModernButton x:Name="btnAddReason" Grid.Row="15" Grid.Column="4" HorizontalAlignment="Right"  IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Define reasons"  Click="btnAddReason_Click" Margin="0,21,0,0"/>

                <mui:ModernButton x:Name="btnSMStoNew" Grid.Row="15" Grid.Column="5" HorizontalAlignment="Left"  IconData="{Binding Data, Source={StaticResource ImgSMS}}"  EllipseDiameter="25" EllipseStrokeThickness="1"  ToolTip="Send SMS"  Click="btnSendSMS_Click" Margin="0,21,0,0"/>

                <Button x:Name="btnSave"  Grid.Row="15" Grid.Column="5"  ToolTip="Save Record" Click="btnSave_Click" Padding="0,0" BorderThickness="1"  Margin="29,5,95,5" >
                    <Image Name="imgSave" Source ="pack://application:,,,/Image/ImgBtnSave.png" Width="60" Height="60" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"   >
                    </Image>
                </Button>
                <Button x:Name="btnDelete"  Grid.Row="15" Grid.Column="5" ToolTip="Delete Record" Padding="0,0" BorderThickness="1" Margin="109,5,11,5" Click="btnDelete_Click"  >
                    <Image Name="imgDelete" Source ="pack://application:,,,/Image/ImgBtnDelete.png" Width="60" Height="60" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"   >
                    </Image>
                </Button>
                <GroupBox x:Name="grpStudentHistory"  Grid.Row="3" Grid.RowSpan="10" Grid.Column="2" Grid.ColumnSpan="4" Header="Student Class History" Margin="20,0,3,0" >
                    <TabControl Name="tabStudentHitory" HorizontalAlignment="Left" Height="Auto" VerticalAlignment="Top" Width="Auto" MaxHeight="400" >
                        <TabItem Header=" Payment ">
                            <GroupBox x:Name="grpNextMonthPayment"  >
                                <GroupBox.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions >
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <mui:ModernButton x:Name="btnNextMonthPayment" Grid.Row="0" Grid.Column="0" IconData="{Binding Data, Source={StaticResource ImgPayment}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Add Next Month Payment" Click="btnNextMonthPayment_Click"/>
                                        <mui:ModernButton x:Name="btnViewEntireHistory" Grid.Row="0" Grid.Column="1"  IconData="{Binding Data, Source={StaticResource ImgHistory}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="View entire class history" Click="btnViewEntireHistory_Click" />
                                        <mui:ModernButton x:Name="btnViewInvoice" Grid.Row="0" Grid.Column="2"  IconData="{Binding Data, Source={StaticResource ImgPrint}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Print Invoice" Click="btnViewInvoice_Click" />
                                    </Grid>

                                </GroupBox.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions >
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="20" />
                                        <RowDefinition Height="5" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer  Height="210" Grid.Row="3" Grid.ColumnSpan="6" >
                                        <DataGrid Name="grdStudentClass"  AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  >
                                            <DataGrid.Columns  >
                                                <DataGridTextColumn Header="STM_YEAR" Binding="{Binding Path=STM_YEAR}" Visibility="Hidden" />
                                                <DataGridTextColumn Header="STM_MONTH" Binding="{Binding Path=STM_MONTH}" Visibility="Hidden" />
                                                <DataGridTextColumn Header="CLS_ID" Binding="{Binding Path=CLS_ID}" Visibility="Hidden" />
                                                <DataGridTextColumn Header="Year" Binding="{Binding Path=STM_YEAR}"  IsReadOnly="True" Visibility="Hidden" />
                                                <DataGridTextColumn Header="ATT_COUNT" Binding="{Binding Path=ATT_COUNT}" Visibility="Hidden" />
                                                <DataGridTextColumn Header="Month" Binding="{Binding Path=STM_MONTH_NAME}"  IsReadOnly="True"  >
                                                    <DataGridTextColumn.CellStyle >
                                                        <Style TargetType="DataGridCell">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding STM_YEAR}" Value="1999">
                                                                    <Setter Property="Background" Value="GreenYellow" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.CellStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Class" Binding="{Binding Path=CLS_NAME}" IsReadOnly="True"  Width="140"  >
                                                    <DataGridTextColumn.CellStyle >
                                                        <Style TargetType="DataGridCell">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding STM_YEAR}" Value="1999">
                                                                    <Setter Property="Background" Value="GreenYellow" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.CellStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Total" Binding="{Binding Path=TO_CLS_COUNT}"  IsReadOnly="True" Width="40" />
                                                <DataGridTemplateColumn Header="Attend" Width="55">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Label Content="{Binding Path=ATT_COUNT}"  />
                                                                <mui:ModernButton x:Name="btnViewHostory" IconData="{Binding Data, Source={StaticResource ImgHistory}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="View Attendance History" Click="btnViewHostory_Click" Margin="15,0,0,0" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridCheckBoxColumn Header="Card" Binding="{Binding Path=CARD_ISSUED_FLG}" IsReadOnly="True" Width="40" />
                                                <DataGridTextColumn Header="Fee" Binding="{Binding Path=CLASS_FEE}"  IsReadOnly="True"  Width="50"/>
                                                <DataGridTextColumn Header="Paid" Binding="{Binding Path=CLASS_FEE_PAYMENT}"  IsReadOnly="True" Width="50" />
                                                <DataGridTextColumn Header="Paid Date" Binding="{Binding Path=STD_REC_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="80" />

                                                <DataGridTemplateColumn Width="40"  >
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <mui:ModernButton x:Name="btnDoPayment" IconData="{Binding Data, Source={StaticResource ImgPayment}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="{Binding Path=STD_REC_DATE}" Click="btnDoPayment_Click" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellStyle >
                                                        <Style TargetType="DataGridCell">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PAY_ARR_FLG}" Value="0">
                                                                    <Setter Property="Background" Value="White" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PAY_ARR_FLG}" Value="1">
                                                                    <Setter Property="Background" Value="Red" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTemplateColumn.CellStyle>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>
                                    <Label Content="Discount"  Grid.Row="1" Grid.Column="1"  />
                                        <Label Content="Late charges " Grid.Row="1"  Grid.Column="3" Grid.ColumnSpan="2"/>
                                        <TextBox x:Name="txtDiscount" Grid.Row="1" Grid.Column="2" IsEnabled="False" TextAlignment="Right"   Width="120" Margin="0,0,10.4,0" />
                                        <TextBox x:Name="txtLatePayment" Grid.Row="1" Grid.Column="4"  IsEnabled="False" Width="100"  TextAlignment="Right" Margin="0,0,20,0" />
                                        <mui:ModernButton x:Name="btnDelayHistory" Grid.Column="4" IconData="{Binding Data, Source={StaticResource ImgHistory}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delay charges History" Margin="118.6,0,0.4,0.4" Grid.RowSpan="2" Click="btnDelayHistory_Click" />
                                   
                                </Grid>                               
                            </GroupBox>
                        </TabItem>
                        <TabItem Header=" Accessory">
                            <GroupBox x:Name="grpAssosory"  >
                                <GroupBox.Header>
                                    <mui:ModernButton x:Name="btnAddNewAssosory" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Add Assosory" Click="btnAddNewAssosory_Click"/>
                                </GroupBox.Header>
                                <ScrollViewer  Height="240"  >
                                    <DataGrid Name="grdAssosory" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0" >
                                        <DataGrid.Resources>
                                            <mycls:DoubleToVisaulConverter x:Key="DoubleToVis" />
                                        </DataGrid.Resources>
                                        <DataGrid.Columns  >
                                            <DataGridTextColumn Header="ID" Binding="{Binding Path=ACC_ID}" IsReadOnly="True"  Width="140" Visibility="Hidden"  />
                                            <DataGridTextColumn Header="Rd" Binding="{Binding Path=ASS_PACK_READY}" IsReadOnly="True" Width="30" Visibility="Hidden"  />
                                            <DataGridTextColumn Header="Accessory" Binding="{Binding Path=ACC_NAME}" IsReadOnly="True"  Width="140"  />
                                            <DataGridTextColumn Header="Issued Date" Binding="{Binding Path=ASS_REC_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="80" />
                                            <DataGridCheckBoxColumn Header="Payble" Binding="{Binding Path=ACC_PAYBLE_FLG}" IsReadOnly="True" Width="50" />
                                            <DataGridTextColumn Header="Amount" Binding="{Binding Path=ASS_REC_AMOUNT}" IsReadOnly="True" Width="100"/>
                                            <DataGridTextColumn Header="Paid Amt" Binding="{Binding Path=PAID_AMOUNT}" IsReadOnly="True" Width="80"/>

                                            <DataGridTemplateColumn Width="30" Header="Re" >
                                                <DataGridTemplateColumn.CellTemplate   >
                                                    <DataTemplate >
                                                        <CheckBox Name="chkRd" IsChecked="{Binding Path=ASS_PACK_READY}" Visibility ="{Binding Path=ACC_DELIVERABLE_FLG}"  IsEnabled= "False" ></CheckBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="30" Header="Di" >
                                                <DataGridTemplateColumn.CellTemplate   >
                                                    <DataTemplate >
                                                        <CheckBox Name="chkDe" IsChecked="{Binding Path=ASS_PACK_DELEVER}"  Visibility ="{Binding Path=ACC_DELIVERABLE_FLG}" IsEnabled= "False" ></CheckBox>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Width="40"  >
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <mui:ModernButton x:Name="btnDoAssosoryPayment" IconData="{Binding Data, Source={StaticResource ImgPayment}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Make Payment" Click="btnDoAssosoryPayment_Click" 
                                                                       Visibility="{Binding Path=ACC_PAYBLE_FLG,Converter={StaticResource DoubleToVis}}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                                <DataGridTemplateColumn.CellStyle >
                                                    <Style TargetType="DataGridCell">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PAY_ARR_FLG}" Value="0">
                                                                <Setter Property="Background" Value="White" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PAY_ARR_FLG}" Value="1">
                                                                <Setter Property="Background" Value="Red" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTemplateColumn.CellStyle>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </ScrollViewer>
                            </GroupBox>
                        </TabItem>
                        <TabItem Header=" Add Classes">
                            <GroupBox x:Name="grpaddClasses"  >
                                <GroupBox.Header>
                                    <mui:ModernButton x:Name="btnAddClasses" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Add Class" Click="btnAddClasses_Click" />
                                </GroupBox.Header>
                                <ScrollViewer  Height="240"  >
                                    <DataGrid Name="grdAddClasses" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0" >
                                        <DataGrid.Columns  >
                                            <DataGridTextColumn Header="CLS_ID" Binding="{Binding Path=CLS_ID}" IsReadOnly="True" Visibility="Hidden" />
                                            <DataGridTextColumn Header="Class Name" Binding="{Binding Path=CLS_NAME}" IsReadOnly="True" Width="250" />
                                            <DataGridTextColumn Header="Class fee" Binding="{Binding Path=STD_CLASS_FEE}" IsReadOnly="True" Width="150"/>
                                            <DataGridTemplateColumn Width="40" >
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <mui:ModernButton x:Name="btnEdit" IconData="{Binding Data, Source={StaticResource ImgEdit}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnEdit_Click_1"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn  Width="40" >
