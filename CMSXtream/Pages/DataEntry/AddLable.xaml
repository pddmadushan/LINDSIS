<UserControl x:Class="CMSXtream.Pages.DataEntry.AddLable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="25" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Label  Grid.Row="0" Grid.Column="0" Content="Label" />
        <Label Name="lblId" Content="-1" Visibility="Hidden"/>
        <TextBox Grid.Row="0" Grid.Column="1" Name="txtReason" TextAlignment="Left" TextChanged="txtReason_TextChanged" />
        <Button x:Name="btnSave"  Grid.Row="0" Grid.Column="2"  ToolTip="Save Record" Padding="0,0" BorderThickness="1" Click="btnSave_Click" >
            <Image Name="imgSave" Source ="pack://application:,,,/Image/ImgBtnSave.png" Width="25" Height="31" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.548"   >
            </Image>
        </Button>
        <DataGrid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Name="grdReason" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False" PreviewMouseDoubleClick="grdReason_PreviewMouseDoubleClick" 
                  ToolTip="Double click on the row needed to be edited" Height = "400"  >
            <DataGrid.Columns  >
                <!--header1-->
                <DataGridTemplateColumn Width="30" Header="CK" >
                    <DataGridTemplateColumn.CellTemplate   >
                        <DataTemplate >
                            <CheckBox Name="chkMark" IsChecked="{Binding Path=LBL_ENABLE}" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked" ></CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--header1-->
                <DataGridTextColumn Header="No" Binding="{Binding Path=LBL_ID}" IsReadOnly="True" Width="70" Visibility="Hidden" />
                <DataGridTextColumn Header="Student Label" Binding="{Binding Path=LBL_DES}" IsReadOnly="True" Width="250"/>
                <DataGridTemplateColumn Header="" Width="45" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <mui:ModernButton x:Name="btnDelete" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delete Lable"  Click="btnDelete_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
