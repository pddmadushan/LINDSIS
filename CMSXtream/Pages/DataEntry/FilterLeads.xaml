<UserControl x:Class="CMSXtream.Pages.DataEntry.FilterLeads"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI" 
             xmlns:mycls="clr-namespace:CMSXtream.Pages.DataEntry" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="0,0,0,0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"  />
            <ColumnDefinition Width="10"  />
            <ColumnDefinition Width="Auto"  />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>
        <GroupBox  Grid.Row="0" Grid.Column="0" Margin="0,3,0,0">
            <GroupBox.Header>
                <Grid Height="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition   />
                    </Grid.RowDefinitions>
                    <Label FontSize="10">Campaigns</Label>
                    <TextBox x:Name="groupTextSearch" FontSize="10" TextChanged="groupTextSearch_TextChanged" Grid.ColumnSpan="1" Margin="35,0,0.2,-0.4" Grid.Column="1" Height="20" />
                    <Label Name="txtGroupCount" FontSize="12" Grid.Column="3" Foreground="#FF0010FF" ></Label>
                </Grid>
            </GroupBox.Header>
            <DataGrid Name="grdCampaign" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False"  Height="261"
                      VerticalAlignment="Top"  FontSize="12" VirtualizingStackPanel.IsVirtualizing="False" MinRowHeight="20"  >
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <DataGridTemplateColumn Width="30" Header="CK" SortMemberPath="chkGrpMark.Check.value" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkCmpMarkAll" Checked="chkCmpMarkAll_Checked" Unchecked="chkCmpMarkAll_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkCmpMark" Checked="chkCmpMark_Checked" Unchecked="chkCmpMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="ID" Binding="{Binding Path=CMP_ID}" IsReadOnly="True" Width="40"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Path=CMP_DES}" IsReadOnly="True" Width="355" />

                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox  Grid.Row="1" Grid.Column="0" FontSize="10" Grid.ColumnSpan="2" Margin="0,10.4,9.2,0" >
            <GroupBox.Header >
                <Grid Height="25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="100" />

                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition   />
                    </Grid.RowDefinitions>
                    <Label FontSize="10">Label</Label>
                    <TextBox x:Name="lableTextSearch" FontSize="10" TextChanged="lableTextSearch_TextChanged" Grid.ColumnSpan="1" Margin="35,0,-0.2,0.2" Height="20" Grid.Column="1"/>
                    <Label Name="lblIncount" FontSize="12" Grid.Column="4" Foreground="#FF0010FF" ></Label>
                    
                </Grid>
            </GroupBox.Header>
            <DataGrid Name="grdLable" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False" Height = "284" VerticalAlignment="Top" VirtualizingStackPanel.IsVirtualizing="False" MinRowHeight="20" FontSize="12">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <DataGridTemplateColumn Width="30" Header="CK" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkLblMark" Checked="chkLblMark_Checked" Unchecked="chkLblMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkLblMarkAll" Checked="chkLblMarkAll_Checked" Unchecked="chkLblMarkAll_Unchecked"></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="No" Binding="{Binding Path=LBL_ID}" IsReadOnly="True" Width="70" Visibility="Hidden" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Path=LBL_DES}" IsReadOnly="True" Width="400"/>
                    <DataGridTextColumn Header="Heads" Binding="{Binding Path=STD_COUNT}" IsReadOnly="True" Width="40"  Visibility="Hidden"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox x:Name="grpBoxStudent" Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" >
            <GroupBox.Header>
                <Grid HorizontalAlignment="Right" Width="635">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="250" />
                        <!--- amila-->
                        <ColumnDefinition Width="200" />

                        <!--- amila-->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <mui:ModernButton x:Name="btnSearchStudent" IconData="{Binding Data, Source={StaticResource ImgSearch}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Search by Advance" Click="btnSearchStudent_Click" Height="25" VerticalAlignment="Center" HorizontalAlignment="Center" Width="22"  />
                    <mui:ModernButton x:Name="btnRefresh" Grid.Row="0" Grid.Column="1" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Refresh data" Click="btnRefresh_Click" Grid.ColumnSpan="2" Height="25" VerticalAlignment="Center" Width="22" />
                    <!--amila-->
                    <!-- <mui:ModernButton x:Name="ExportCsv" Grid.Row="0" Grid.Column="4" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Refresh data" Grid.ColumnSpan="2" Margin="4.6,0,29.4,-0.2" Click="ExportCsv_Click" />-->
                    <Button x:Name="ExportCsv" Content="Export" Grid.Row="0" Grid.Column="4"   ToolTip="Exoprt Mobile Numbers to CSV File" Margin="102,0,108,0" Click="ExportCsv_Click" />
                    <!--amila-->
                    <Label x:Name="lblCount" Grid.Row="0" Grid.Column="3" />
                </Grid>
            </GroupBox.Header>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="66"/>
                    <ColumnDefinition Width="19"/>
                    <ColumnDefinition Width="85"/>
                    <ColumnDefinition Width="85"/>
                </Grid.ColumnDefinitions>
                <DataGrid Name="grdLeadList" AutoGenerateColumns="False"  CanUserAddRows="False" CanUserDeleteRows="True" 
                          RowHeaderWidth="35" Height="540" VerticalAlignment="Top" VirtualizingStackPanel.IsVirtualizing="False" 
                           LoadingRow="DataGrid_LoadingRow" Grid.ColumnSpan="4" MinRowHeight="30">
                    <DataGrid.Columns  >
                        <DataGridTemplateColumn Width="30" Header="CK" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate >
                                    <CheckBox Name="chkSMSMark" IsChecked="{Binding Path=IS_SELECT}"></CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox Name="chkSMSMarkAll" Checked="chkSMSMarkAll_Checked" Unchecked="chkSMSMarkAll_Unchecked"></CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ID" Binding="{Binding Path=CMP_STD_ID}" IsReadOnly="True"  Width="75" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Path=STD_FULL_NAME}" IsReadOnly="True" Width="200" />
                        <DataGridTextColumn Header="Telephone" Binding="{Binding Path=STD_TELEPHONE}" IsReadOnly="True" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
