<UserControl x:Class="CMSXtream.Pages.DataEntry.CampaingName"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             xmlns:local="clr-namespace:CMSXtream.Control"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources >
        <!---need to add icons like delete-->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid x:Name="campdata">
        <Label x:Name="cmplbl" Content="-1" HorizontalAlignment="Left" Height="40" Margin="27,10,0,0" VerticalAlignment="Top" Width="191" FontWeight="Bold" FontSize="14" Visibility="Hidden"/>
        <TextBox x:Name="TextAddcmp" HorizontalAlignment="Left" Height="31" Margin="131,10,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="349" />
        <Button x:Name="cmpsave"  HorizontalAlignment="Left"  Margin="565,9,0,0" VerticalAlignment="Top" Click="cmpsave_Click" Width="60" Height="32">
            <Image Name="imgSave" Source ="pack://application:,,,/Image/ImgBtnSave.png" Width="25" Height="31" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" RenderTransformOrigin="0.5,0.548"   >
            </Image>
        </Button>


        <DataGrid x:Name="cmpdatagrid" Grid.Column="0" CanUserAddRows="False" CanUserDeleteRows="False" HorizontalAlignment="Left" Height="128" Margin="10,67,0,0" 
           HeadersVisibility="Column"       VerticalAlignment="Top" Width="609"  AutoGenerateColumns="False" 
                  FontSize="16" IsReadOnly="True" Background="White" PreviewMouseDoubleClick="cmpdatagrid_PreviewMouseDoubleClick" ToolTip="Double click to edit" >
            <!-- HeadersVisibility="Column" remove blank spaced column from left side -->
            <!-- SET COMMER COLUR TO ALL HEADERS Text color -->


            <!-- SET COMMEN COLUR TO ALL HEADERS Text color -->

            <DataGrid.Columns>
                <!-- id   -->
                <DataGridTextColumn Width="30" Header="cmp_id" Binding="{Binding Path=CMP_ID}"   >
                    <!-- Visibility="Hidden" to hide cmp_id column-->
                </DataGridTextColumn>

                <!-- campain names   -->
                <DataGridTextColumn Width="*" Header="Camapain Name" Binding="{Binding Path=CMP_DES}" />
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding Path=IS_ACTIVE}" IsReadOnly="True" Width="100" />





                <!-- Column 4: Delete Button -->
                <DataGridTemplateColumn Header="" Width="45">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>

                            <!-- <Button Content="Click Me" Click="Button_Delete" />-->
                            <mui:ModernButton x:Name="btnDelete" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delete Lable"  Click="btnDelete_Click" />
                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Campaign" HorizontalAlignment="Left" Height="40" Margin="10,10,0,0" VerticalAlignment="Top" Width="110" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Top"/>
        <CheckBox x:Name="cmpActiveChk" Content="Active" HorizontalAlignment="Left" Height="50" Margin="487,0,0,0" VerticalAlignment="Top" Width="86" FontSize="16" FontWeight="Bold" />
        <Button x:Name="btnAddNewCampaign" Content="+Add New" HorizontalAlignment="Left" Height="32" Margin="648,9,0,0" VerticalAlignment="Top" Width="107" FontSize="12" Click="btnAddNewCampaign_Click" ToolTip="click to Add new Campaign" Background="AliceBlue" />

    </Grid>
</UserControl>
