<UserControl x:Class="CMSXtream.Pages.DataEntry.StudentFiltersAdvance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI" 
             xmlns:mycls="clr-namespace:CMSXtream.Pages.DataEntry" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="0,0,0,0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"  />
            <ColumnDefinition Width="10"  />
            <ColumnDefinition Width="Auto"  />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <GroupBox  Grid.Row="0" Grid.Column="0" Margin="0,3,0,0">
            <GroupBox.Header>
                <Grid Height="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition   />
                    </Grid.RowDefinitions>
                    <Label FontSize="10">Group</Label>
                    <TextBox x:Name="groupTextSearch" FontSize="10" TextChanged="groupTextSearch_TextChanged" Grid.Column="1" Height="18" VerticalAlignment="Top" />
                    <Label Name="txtGroupCount" FontSize="12" Grid.Column="3" Foreground="#FF0010FF" ></Label>
                </Grid>
            </GroupBox.Header>
            <DataGrid Name="grdGroup" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False" Height = "150" 
                      VerticalAlignment="Top" Margin="0,5,0,0" FontSize="10" VirtualizingStackPanel.IsVirtualizing="False"  >
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <DataGridTemplateColumn Width="30" Header="CK" SortMemberPath="chkGrpMark.Check.value" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkGrpMarkAll" Checked="chkGrpMarkAll_Checked" Unchecked="chkGrpMarkAll_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkGrpMark" Checked="chkGrpMark_Checked" Unchecked="chkGrpMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="ID" Binding="{Binding Path=CLS_ID}" IsReadOnly="True" Width="40"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Path=CLS_NAME}" IsReadOnly="True" Width="310"/>
                    <DataGridTextColumn Header="Class" Binding="{Binding Path=IS_CLASS_FLG}" IsReadOnly="True" Width="40"/>
                    <DataGridTextColumn Header="Heads" Binding="{Binding Path=STD_COUNT}" Visibility="Hidden" Width="40"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox  Grid.Row="1" Grid.Column="0" FontSize="10" Grid.ColumnSpan="2" Margin="0,10.4,9.2,0" >
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="35" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="15" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition   />
                    </Grid.RowDefinitions>
                    <Label FontSize="10">Label</Label>
                    <TextBox x:Name="lableTextSearch" FontSize="10" TextChanged="lableTextSearch_TextChanged" Grid.ColumnSpan="2" Margin="35,0,-0.2,0.2" />
                    <Label FontSize="12" Grid.Column="3">In</Label>
                    <Label Name="lblIncount" FontSize="12" Grid.Column="4" Foreground="#FF0010FF" ></Label>
                    <Label FontSize="12" Grid.Column="6">Not</Label>
                    <Label Name="lblOntIncount" FontSize="12" Grid.Column="7" Foreground="#FF0810FF" ></Label>
                </Grid>
            </GroupBox.Header>
            <DataGrid Name="grdLable" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False" Height = "150" VerticalAlignment="Top" Margin="0,5,0,0" VirtualizingStackPanel.IsVirtualizing="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <DataGridTemplateColumn Width="30" Header="CK" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkLblMark" Checked="chkLblMark_Checked" Unchecked="chkLblMark_Unchecked" ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkLblMarkAll" Checked="chkLblMarkAll_Checked" Unchecked="chkLblMarkAll_Unchecked"></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="No" Binding="{Binding Path=LBL_ID}" IsReadOnly="True" Width="70" Visibility="Hidden" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Path=LBL_DES}" IsReadOnly="True" Width="300"/>
                    <DataGridTemplateColumn Header="" Width="30" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <mui:ModernButton x:Name="btnLblAddtoAll" IconData="{Binding Data, Source={StaticResource ImgAddStudents}}"  EllipseDiameter="15" EllipseStrokeThickness="1" ToolTip="Add Lable to All Students" Click="btnLblAddtoAll_Click"  />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="30" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <mui:ModernButton x:Name="btnLblDeletefromAll" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="15" EllipseStrokeThickness="1" ToolTip="Delete Lable from All Students" Click="btnLblDeletefromAll_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Heads" Binding="{Binding Path=STD_COUNT}" IsReadOnly="True" Width="40"  Visibility="Hidden"/>
                    <DataGridTemplateColumn Width="30" Header="NT" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkLblMarkN" ToolTip="Not included" Checked="chkLblMarkN_Checked" Unchecked="chkLblMarkN_Unchecked"  ></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkLblMarkAllN" Checked="chkLblMarkAllN_Checked" Unchecked="chkLblMarkAllN_Unchecked" ToolTip="Not included"></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox  Grid.Row="2" Grid.Column="0" >
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <mui:ModernButton x:Name="btnAddStudentBySearch" Grid.Row="0" Grid.Column="1" IconData="{Binding Data, Source={StaticResource ImgAddStudent}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Add Student" Click="btnAddStudentBySearch_Click"  />
                    <Label x:Name="filterString" Grid.Row="0" Grid.Column="0" FontSize="10" Margin="0,10,0,0">Student</Label>
                </Grid>
            </GroupBox.Header>
            <DataGrid Name="grdStudent" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="True" Height = "200" VerticalAlignment="Top" FontSize="10" VirtualizingStackPanel.IsVirtualizing="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Background" Value="Blue" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns  >
                    <DataGridTemplateColumn Width="30" Header="CK" >
                        <DataGridTemplateColumn.CellTemplate   >
                            <DataTemplate >
                                <CheckBox Name="chkStdntMark"></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Name="chkStdntMarkAll"  Unchecked="chkStdntMarkAll_Unchecked" Checked="chkStdntMarkAll_Checked"></CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="ID" Binding="{Binding Path=STD_ID}" IsReadOnly="True"  Width="50" />
                    <DataGridTextColumn Header="Student Name" Binding="{Binding Path=STD_INITIALS}" IsReadOnly="True" Width="170" />
                    <DataGridTextColumn Header="Class" Binding="{Binding Path=CLS_NAME}" IsReadOnly="True" Width="200" />
                    <DataGridTemplateColumn Width="25" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <mui:ModernButton x:Name="btnStdntView" IconData="{Binding Data, Source={StaticResource ImgEdit}}"  EllipseDiameter="15" EllipseStrokeThickness="1" ToolTip="View Record" Click="btnStdntView_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle >
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding STD_PAID_STATUS}" Value="0">
                                        <Setter Property="Background" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding STD_PAID_STATUS}" Value="1">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <GroupBox x:Name="grpBoxStudent" Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" >
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="250" />
                        <!--- amila-->
                        <ColumnDefinition Width="303" />

                        <!--- amila-->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>
                    <mui:ModernButton x:Name="btnSearchStudent" IconData="{Binding Data, Source={StaticResource ImgSearch}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Search by Advance" Click="btnSearchStudent_Click" Height="25" VerticalAlignment="Center" HorizontalAlignment="Center" Width="22"  />
                    <mui:ModernButton x:Name="btnRefresh" Grid.Row="0" Grid.Column="1" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Refresh data" Click="btnRefresh_Click" Grid.ColumnSpan="2" Margin="5,0,29,0" />
                    <mui:ModernButton x:Name="btnSendSMSALL" Grid.Row="0" Grid.Column="2" IconData="{Binding Data, Source={StaticResource ImgSMS}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Send SMS" Click="btnSendSMSALL_Click"  />
                    <!--amila-->
                    <!-- <mui:ModernButton x:Name="ExportCsv" Grid.Row="0" Grid.Column="4" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Refresh data" Grid.ColumnSpan="2" Margin="4.6,0,29.4,-0.2" Click="ExportCsv_Click" />-->
                    <Button x:Name="ExportCsv" Content="Export" Grid.Row="0" Grid.Column="4"   ToolTip="Exoprt Mobile Numbers to CSV File" Margin="102,0,108,0" Click="ExportCsv_Click" />
                    <!--amila-->
                    <Label x:Name="lblCount" Grid.Row="0" Grid.Column="3" />
                </Grid>
            </GroupBox.Header>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="66*"/>
                    <ColumnDefinition Width="19*"/>
                    <ColumnDefinition Width="85*"/>
                </Grid.ColumnDefinitions>
                <DataGrid Name="grdSMSList" AutoGenerateColumns="False"  CanUserAddRows="False" CanUserDeleteRows="True" 
                          RowHeaderWidth="35" Height="590" VerticalAlignment="Center" VirtualizingStackPanel.IsVirtualizing="False" 
                           LoadingRow="DataGrid_LoadingRow" Grid.ColumnSpan="3">
                    <DataGrid.Resources>
                        <mycls:DoubleToVisaulConverter x:Key="DoubleToVis" />
                    </DataGrid.Resources>
                    <DataGrid.Columns  >
                        <DataGridTemplateColumn Width="30" Header="CK" >
                            <DataGridTemplateColumn.CellTemplate   >
                                <DataTemplate >
                                    <CheckBox Name="chkSMSMark" IsChecked="{Binding Path=IS_SELECT}"></CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox Name="chkSMSMarkAll" Checked="chkSMSMarkAll_Checked" Unchecked="chkSMSMarkAll_Unchecked"></CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="ID" Binding="{Binding Path=CLS_ID}" IsReadOnly="True"  Width="100" Visibility="Hidden" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Path=STD_ID}" IsReadOnly="True"  Width="50" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Path=STD_INITIALS}" IsReadOnly="True" Width="140" />
                        <DataGridTextColumn Header="Class" Binding="{Binding Path=CLS_NAME}" IsReadOnly="True" Width="200" />
                        <DataGridTextColumn Header="Telephone" Binding="{Binding Path=STD_TELEPHONE}" IsReadOnly="True" Width="85" />
                        <DataGridTemplateColumn Width="31" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <mui:ModernButton x:Name="btnEdit" IconData="{Binding Data, Source={StaticResource ImgEdit}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnEdit_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellStyle >
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding STD_PAID_STATUS}" Value="0">
                                            <Setter Property="Background" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding STD_PAID_STATUS}" Value="1">
                                            <Setter Property="Background" Value="Red" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn  Width="31" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <mui:ModernButton x:Name="btnComments" IconData="{Binding Data, Source={StaticResource ImgAlert}}"  EllipseDiameter="25" EllipseStrokeThickness="0" ToolTip="{Binding Path= STD_TEMP_NOTE }"  
                                                                       Visibility="{Binding Path=STD_COMMENT_FLG,Converter={StaticResource DoubleToVis}}" Click="btnComments_Click"  />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellStyle >
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding STD_COMMENT_FLG}" Value="0">
                                            <Setter Property="Background" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding STD_COMMENT_FLG}" Value="1">
                                            <Setter Property="Background" Value="#FFFFF300" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn  Width="45" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Label FontSize="11" Grid.Column="0" FontWeight="Bold" Content="{Binding Path= LBL_COUNT }"/>
                                        <mui:ModernButton  Grid.Column="1" x:Name="btnAddLable" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Show Lable" Click="btnAddLable_Click" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Fee" IsReadOnly="True" Width="32"  >
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IS_CAUSE_FEE}" Value="0">
                                            <Setter Property="Background" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IS_CAUSE_FEE}" Value="1">
                                            <Setter Property="Background" Value="GreenYellow" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
