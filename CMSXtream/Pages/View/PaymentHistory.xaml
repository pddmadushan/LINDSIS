<UserControl x:Class="CMSXtream.Pages.View.PaymentHistory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMSXtream.Pages.View"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="700">
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="5" />
            <RowDefinition Height="35" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Content="Release Date" Margin="0,10,0,0" />
        <DatePicker Name="dtpReleaseDate" Grid.Row="2" Grid.Column="0" />
        <Label Grid.Row="0" Grid.Column="1" Content="Release Amount" Grid.ColumnSpan="2" Margin="10,0,149,0" />
        <TextBox Grid.Row="2" Grid.Column="1" Name="txtReleasePayment" PreviewTextInput="NumberValidationTextBox" TextAlignment="Right" Margin="10,0.4,0,5.2"  MaxLength="6" Grid.RowSpan="2" />
        <TextBox  x:Name="txtComment"  Grid.Row="0" Grid.ColumnSpan="2"  Grid.RowSpan="4"  Grid.Column="2"  MaxLength="250" TextWrapping="Wrap" AcceptsReturn="True" Margin="28,0,10,5.2"/>

        <Button  x:Name="btnRelease" Grid.Row="2" Grid.Column="4" Background="LightBlue" Content="Release" FontWeight="Bold" Click="Button_Click"/>
        <DataGrid Name="grdPaymentHistory" Grid.Row="4" Grid.ColumnSpan="5" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0" EnableRowVirtualization = "True"  CanUserDeleteRows="False"  >
            <DataGrid.Columns  >
                <DataGridTextColumn Header="Release Date" Binding="{Binding Path=RELEASE_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="100" />
                <DataGridCheckBoxColumn Header="Amount" Binding="{Binding Path=RELEASE_AMT}" IsReadOnly="True"  Width="100"/>
                <DataGridTextColumn Header="User" Binding="{Binding Path=MODIFY_USER}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Audit Date" Binding="{Binding Path=MODIFY_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="100" />
                <DataGridTextColumn Header="Comment" Binding="{Binding Path=USER_COMMENT}" IsReadOnly="True" Width="250" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
