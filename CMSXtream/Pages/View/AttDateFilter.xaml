<UserControl x:Class="CMSXtream.Pages.View.AttDateFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMSXtream.Handlers"
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             mc:Ignorable="d" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:IntValueToVisibilityConverter x:Key="IntValueToVisibilityConverter"/>
            <local:IntValueToVisibilityConverterZeroValue x:Key="IntValueToVisibilityConverterZeroValue"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0">
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>
                    <ComboBox x:Name="cmbUser" Width="200" Height="25" Grid.Column="0" HorizontalAlignment="Left" />
                    <DatePicker x:Name="dtpFollowingFromDate" Width="140" Height="25" Grid.Column="1" HorizontalAlignment="Center" IsEnabled="True" >
                        <DatePicker.Resources >
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="IsReadOnly" Value="True"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                    <DatePicker x:Name="dtpFollowingToDate" Width="140" Height="25" Grid.Column="3" HorizontalAlignment="Center" Visibility="Hidden" >
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox" >
                                <Setter Property="IsReadOnly" Value="True"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                    <Button x:Name="btnSearch" Grid.Column="3" Width="110" Height="25" Content="Search" Click="btnSearch_Click"  Grid.Row="1" HorizontalAlignment="Left"/>
                    <Border Grid.Row="0" Grid.Column="5"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="LightGreen" RenderTransformOrigin="0.4,-0.35" Width="50" HorizontalAlignment="Left" />
                    <Label Content="Reg" Height="25" Foreground="Black" Grid.Column="5" HorizontalAlignment="Left" Margin="7,6,0,0" />
                    <Border Grid.Row="0" Grid.Column="6"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="Yellow" RenderTransformOrigin="0.4,-0.35" Width="50" HorizontalAlignment="Left" />
                    <Label Content="UnReg" Height="25" Foreground="Black" Grid.Column="6" HorizontalAlignment="Left" Margin="7,6,0,0" />
                    <Border Grid.Row="0" Grid.Column="7"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="red" RenderTransformOrigin="0.4,-0.35" Width="60" HorizontalAlignment="Left" />
                    <Label Content="Deleted" Height="25" Foreground="Black" Grid.Column="7" HorizontalAlignment="Left" Margin="7,6,0,0" />
                    <Border Grid.Row="0" Grid.Column="8"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="Purple" RenderTransformOrigin="0.4,-0.35" Width="130" HorizontalAlignment="Left" />
                    <Label Content="No More Attention" Height="25" Foreground="White" Grid.Column="8" HorizontalAlignment="Left" Margin="7,6,0,0"/>
                </Grid>
            </GroupBox.Header>
            <DataGrid x:Name="grdLeadData" AutoGenerateColumns="False" HorizontalAlignment="Left"  Height="auto" d:ItemsSource="{d:SampleData}" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" MinRowHeight="30" LoadingRow="DataGrid_LoadingRow" RowHeaderWidth="35" Margin="0,5,0,0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#ccd5d5"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderBrush" Value="#ccd5d5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="CMP_STD_ID" Width="10" Binding="{Binding CMP_STD_ID}" Header="CMP_STD_ID" Visibility="Hidden"/>
                    <DataGridTextColumn  Width="25" Binding="{Binding ISREG_STD}" Header="" Visibility="Visible">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ISREG_STD}" Value="Yes">
                                        <Setter Property="Background" Value="LightGreen"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ISREG_STD}" Value="No">
                                        <Setter Property="Background" Value="Yellow"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NO_MORE_ATTENTION_FLG}" Value="1">
                                        <Setter Property="Background" Value="Purple"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IS_DELETED}" Value="1">
                                        <Setter Property="Background" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn x:Name="clmHistory" Width="120" Header="Name">
                        <DataGridTemplateColumn.CellTemplate >
                            <DataTemplate >
                                <StackPanel Orientation="Vertical"  >
                                    <TextBlock x:Name="textBlock1" Text="{Binding STD_FULL_NAME }"  TextWrapping="Wrap" />
                                    <mui:ModernButton x:Name="btnHistory" IconData="{Binding Data, Source={StaticResource ImgHistory}}" EllipseDiameter="24" EllipseStrokeThickness="1" ToolTip="Show history"  Click="btnHistory_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="STD_TELEPHONE" Width="85" Binding="{Binding STD_TELEPHONE}" Header="Phone" Visibility="Visible"/>
                    <DataGridTemplateColumn x:Name="userInfo" Header="Info " Width="180"  >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock x:Name="textBlock1" Text="{Binding bandscore }"  />
                                    <TextBlock x:Name="textBlock2"  Text="{Binding exam_type}" />
                                    <TextBlock x:Name="textBlock3"  Text="{Binding when_do_you_want}"  />
                                    <TextBlock x:Name="textBlock4"  Text="{Binding your_english_knowledge}"  />
                                    <TextBlock x:Name="textBlock5"  Text="{Binding your_ielts_knowledge}"  />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="33">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="CellBorder" Padding="5" >
                                    <StackPanel Orientation="Vertical">
                                        <mui:ModernButton VerticalAlignment="Bottom" x:Name="btnAddLable" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="18" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnAddLable_Click" />
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers >
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="0" >
                                        <Setter TargetName="CellBorder" Property="Background" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="1">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#e81a86" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="2">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#24a799" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="3">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#f4b907" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="500" Binding="{Binding COMMENT_OLD}" Header="Comment" Visibility="Visible">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="*" Binding="{Binding LABLES_OLD}" Header="Lables" Visibility="Visible" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="ToolTip" Value="{Binding LABLES_OLD}" />
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>                    
                    <DataGridTextColumn  Width="85" Binding="{Binding NEXT_FOLLOWING_DATE}" Header="Next &#x0a;Fllwing Date" Visibility="Visible"/>
                    <DataGridTextColumn  Width="60" Binding="{Binding CLS_USER_ID}" Header="Current &#x0a;User" Visibility="Visible"/>
                    <DataGridTextColumn  Width="69" Binding="{Binding LABLE_LAST_MOD_USER}" Header="Last Mod &#x0a;User" Visibility="Visible"/>
                    <DataGridTextColumn  Width="85" Binding="{Binding LAST_MOD_DATE}" Header="Last Mod &#x0a;Date" Visibility="Visible"/>
                    <DataGridTextColumn x:Name="isDeleted" Width="125" Binding="{Binding IS_DELETED}" Header="IS_DELETED" Visibility="Hidden"/>
                    <DataGridTextColumn x:Name="CMP_DES" Width="50" Binding="{Binding CMP_DES}" Header="Campaign &#x0a;Name" Visibility="Hidden"/>
                    <DataGridTextColumn x:Name="ADD_DES" Width="90" Binding="{Binding ADD_DES}" Header="Add &#x0a;Name" Visibility="Hidden"/>
                    <DataGridTemplateColumn x:Name="clmTransferLead" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical">
                                    <mui:ModernButton x:Name="btnAddStudent" IconData="{Binding Data, Source={StaticResource ImgAttendance}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Change Lead as Student" Click="btnAddStudent_Click" Visibility="{Binding ISNOT_CLS_STD, Converter={StaticResource IntValueToVisibilityConverter}}" />
                                    <mui:ModernButton x:Name="btnTranferLead" IconData="{Binding Data, Source={StaticResource ImgTransfers}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Tranfer leads to another user" Click="btnTranferLead_Click"/>
                                    <mui:ModernButton x:Name="btnRestoreStudent" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Restore delted student" Visibility="{Binding IS_DELETED, Converter={StaticResource IntValueToVisibilityConverter}}" Click="btnRestoreStudent_Click" />
                                    <mui:ModernButton x:Name="btnDeleteStudent" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delet selected student" Click="btnDeleteStudent_Click" Visibility="{Binding IS_DELETED, Converter={StaticResource IntValueToVisibilityConverterZeroValue}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>