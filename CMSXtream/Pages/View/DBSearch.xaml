<UserControl x:Class="CMSXtream.Pages.View.DBSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             xmlns:local="clr-namespace:CMSXtream.Handlers"
             mc:Ignorable="d" >
    <UserControl.Resources >
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/IconLibrary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:IntValueToVisibilityConverter x:Key="IntValueToVisibilityConverter"/>
            <local:IntValueToVisibilityConverterZeroValue x:Key="IntValueToVisibilityConverterZeroValue"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="850"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <GroupBox Grid.Row="0" Grid.Column="0">
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="225"/>
                        <ColumnDefinition Width="225"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cmbUser" Width="200" Height="25" Grid.Column="0" HorizontalAlignment="Left" />
                    <ComboBox x:Name="cmbAddOrCmp" Grid.Column="1" Width="220" Height="25" SelectionChanged="cmbAddOrCmp_SelectionChanged" HorizontalAlignment="Left"/>
                    <ComboBox x:Name="cmbLoadedAddOrCmp" Grid.Column="2" Width="220" Height="25" HorizontalAlignment="Right"/>
                    <mui:ModernButton x:Name="btnSendSMSALL" Grid.Column="4" IconData="{Binding Data, Source={StaticResource ImgSMS}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Send SMS" Height="27" Click="btnSendSMSALL_Click" />
                </Grid>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Column="0" Height="70" Margin="0,5,0,0">
                    <GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Enable Lead Added Date filter" Width="200" Grid.Column="0"/>
                            <CheckBox x:Name="chkEnableDateFilter" Grid.Column="1" HorizontalAlignment="Right" ToolTip="Enable Date Filter" Checked="chkEnableDateFilter_Checked" Unchecked="chkEnableDateFilter_Unchecked"/>
                        </Grid>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="dtpFromDate" Width="140" Height="25" Grid.Column="0" HorizontalAlignment="Center" IsEnabled="False" >
                            <DatePicker.Resources >
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="IsReadOnly" Value="True"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                        <Label Content="To" Height="25" Grid.Column="1" HorizontalAlignment="Center" IsEnabled="False" />
                        <DatePicker x:Name="dtpToDate" Width="140" Height="25" Grid.Column="2" HorizontalAlignment="Center" IsEnabled="False" >
                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox" >
                                    <Setter Property="IsReadOnly" Value="True"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="2" Height="70" Margin="0,5,0,0" >
                    <GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Enable Attending Date filter" Width="170" Grid.Column="0"/>
                            <CheckBox x:Name="chkEnableAttDateFilter" Grid.Column="1" HorizontalAlignment="Right" ToolTip="Enable Date Filter" Checked="chkEnableAttDateFilter_Checked" Unchecked="chkEnableAttDateFilter_Unchecked"/>
                        </Grid>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="dtpAttFromDate" Width="140" Height="25" Grid.Column="0" HorizontalAlignment="Center" IsEnabled="False" >
                            <DatePicker.Resources >
                                <Style TargetType="DatePickerTextBox">
                                    <Setter Property="IsReadOnly" Value="True"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                        <Label Content="To" Height="25" Grid.Column="1" HorizontalAlignment="Center" IsEnabled="False" />
                        <DatePicker x:Name="dtpAttToDate" Width="140" Height="25" Grid.Column="2" HorizontalAlignment="Center" IsEnabled="False" >
                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox" >
                                    <Setter Property="IsReadOnly" Value="True"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="4" Height="70" Margin="0,5,0,0">
                    <GroupBox.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Priority" Width="70" Grid.Column="0"/>
                            <CheckBox x:Name="chkP" Grid.Column="1" HorizontalAlignment="Right" ToolTip="Enable Prority Levels" Checked="chkP_Checked" Unchecked="chkP_Unchecked" />
                        </Grid>
                    </GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbP" Grid.Column="0" Width="80" Height="25" Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Left" IsEnabled="False" />
                    </Grid>
                </GroupBox>
                <ComboBox x:Name="cmbTpOrName" Grid.Column="0" Width="180" Height="25" Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Left" SelectionChanged="cmbTpOrName_SelectionChanged" />
                <TextBox x:Name="txtbox" Grid.Column="0" Grid.ColumnSpan="3"  Width="380" Height="25"  Grid.Row="1" Margin="190,0,0,0" HorizontalAlignment="Left" />
                <Button x:Name="btnSearch" Grid.Column="2" Width="110" Height="25" Content="Search" Click="btnSearch_Click"  Grid.Row="1" HorizontalAlignment="Right"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="0" Grid.Column="1">
            <GroupBox.Header >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Summery" Height="25" Foreground="Red" Grid.Column="0"  />
                    <Border Grid.Row="0" Grid.Column="1"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="LightGreen" RenderTransformOrigin="0.4,-0.35" Width="50" HorizontalAlignment="Left" />
                    <Label Content="Reg" Height="25" Foreground="Black" Grid.Column="1" HorizontalAlignment="Left" Margin="7,6,0,0" />
                    <Border Grid.Row="0" Grid.Column="2"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="Yellow" RenderTransformOrigin="0.4,-0.35" Width="50" HorizontalAlignment="Left" />
                    <Label Content="UnReg" Height="25" Foreground="Black" Grid.Column="2" HorizontalAlignment="Left" Margin="7,6,0,0"/>
                    <Border Grid.Row="0" Grid.Column="3"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="Purple" RenderTransformOrigin="0.4,-0.35"  Width="55" HorizontalAlignment="Left" />
                    <Label Content="No Att." Height="25" Foreground="Black" Grid.Column="3" HorizontalAlignment="Left" Margin="7,6,0,0"/>
                    <Border Grid.Row="0" Grid.Column="4"  BorderThickness="1" CornerRadius="5,0,5,0" BorderBrush="Black" Height="20" Background="red" RenderTransformOrigin="0.4,-0.35"  />
                    <Label Content="Deleted" Height="25" Foreground="Black" Grid.Column="4" HorizontalAlignment="Left" Margin="7,6,0,0"/>
                </Grid>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Label Content="Total Record " Grid.Row="0" Grid.Column="0"/>
                <Label Content="Registered Student " Grid.Row="1" Grid.Column="0"/>
                <Label Content="UnRegistered Student " Grid.Row="2" Grid.Column="0"/>
                <Label Content="Deleted Leads " Grid.Row="3" Grid.Column="0"/>
                <Label Content="No more attention " Grid.Row="4" Grid.Column="0"/>
                <Label Content=":" Grid.Column="1" Grid.Row="0"/>
                <Label Content=":" Grid.Column="1" Grid.Row="1"/>
                <Label Content=":" Grid.Column="1" Grid.Row="2"/>
                <Label Content=":" Grid.Column="1" Grid.Row="3"/>
                <Label Content=":" Grid.Column="1" Grid.Row="4"/>
                <Label x:Name="lblTotal" Content="0" Grid.Column="2" Grid.Row="0"/>
                <Label x:Name="lblReg" Content="0" Grid.Column="2" Grid.Row="1"/>
                <Label x:Name="lblUnReg" Content="0"  Grid.Column="2" Grid.Row="2"/>
                <Label x:Name="lblDelRec" Content="0"  Grid.Column="2" Grid.Row="3"/>
                <Label x:Name="lblNoMrAttRec" Content="0"  Grid.Column="2" Grid.Row="4"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0">
            <DataGrid x:Name="grdLeadData" PreviewMouseWheel="DataGrid_PreviewMouseWheel" AutoGenerateColumns="False" HorizontalAlignment="Left"  Height="auto" d:ItemsSource="{d:SampleData}" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" MinRowHeight="30" LoadingRow="DataGrid_LoadingRow" RowHeaderWidth="35" Margin="0,5,0,0" >
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="TextBlock.TextAlignment" Value="Left"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#ccd5d5"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderBrush" Value="#ccd5d5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="STD_ID" Width="30" Binding="{Binding STD_ID}" Header="STD_ID" Visibility="Hidden"/>
                    <DataGridTextColumn x:Name="CMP_STD_ID" Width="30" Binding="{Binding CMP_STD_ID}" Header="CMP_STD_ID" Visibility="Hidden"/>
                    <DataGridTextColumn  Width="50" Binding="{Binding IS_REGISTERED}" Header="Is Reg:" Visibility="Visible">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IS_REGISTERED}" Value="Yes">
                                        <Setter Property="Background" Value="LightGreen"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IS_REGISTERED}" Value="No">
                                        <Setter Property="Background" Value="Yellow"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IS_DELETED}" Value="1">
                                        <Setter Property="Background" Value="Red"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NO_MORE_ATTENTION}" Value="1">
                                        <Setter Property="Background" Value="Purple"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn x:Name="clmHistory" Width="120" Header="Name">
                        <DataGridTemplateColumn.CellTemplate >
                            <DataTemplate >
                                <StackPanel Orientation="Vertical"  >
                                    <TextBlock x:Name="textBlock1" Text="{Binding STD_FULL_NAME }"  TextWrapping="Wrap" />
                                    <mui:ModernButton x:Name="btnHistory" IconData="{Binding Data, Source={StaticResource ImgHistory}}" EllipseDiameter="24" EllipseStrokeThickness="1" ToolTip="Show history"  Click="btnHistory_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="STD_TELEPHONE" Width="100" Binding="{Binding STD_TELEPHONE}" Header="Phone" Visibility="Visible"/>
                    <DataGridTemplateColumn x:Name="userInfo" Header="Info " Width="180"  >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock x:Name="textBlock1" Text="{Binding bandscore }"  />
                                    <TextBlock x:Name="textBlock2"  Text="{Binding exam_type}" />
                                    <TextBlock x:Name="textBlock3"  Text="{Binding when_do_you_want}"  />
                                    <TextBlock x:Name="textBlock4"  Text="{Binding your_english_knowledge}"  />
                                    <TextBlock x:Name="textBlock5"  Text="{Binding your_ielts_knowledge}"  />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="CellBorder" Padding="5" >
                                    <StackPanel Orientation="Vertical">
                                        <mui:ModernButton VerticalAlignment="Bottom" HorizontalAlignment="Center" x:Name="btnAddLable" IconData="{Binding Data, Source={StaticResource ImgAddTute}}"  EllipseDiameter="20" EllipseStrokeThickness="1" ToolTip="Edit Record"  Click="btnAddLable_Click" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers >
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="0" >
                                        <Setter TargetName="CellBorder" Property="Background" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="1">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#e81a86" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="2">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#24a799" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PRORITY_VALUE}" Value="3">
                                        <Setter TargetName="CellBorder" Property="Background" Value="#f4b907" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Width="500" Binding="{Binding USER_COMMENT}" Header="Comment" Visibility="Visible">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="*" Binding="{Binding CMP_STD_LBL}" Header="Lables" Visibility="Visible" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="ToolTip" Value="{Binding CMP_STD_LBL}" />
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>                    
                    <DataGridTextColumn  Width="85" Binding="{Binding NEXT_FOLLOWING_DATE}" Header="Next &#x0a;Fllwing Date" Visibility="Visible"/>
                    <DataGridTextColumn  Width="60" Binding="{Binding ASSIGNED_USER}" Header="Current &#x0a;User" Visibility="Visible"/>
                    <DataGridTextColumn  Width="69" Binding="{Binding LABLE_LAST_MOD_USER}" Header="Last Mod &#x0a;User" Visibility="Visible"/>
                    <DataGridTextColumn  Width="85" Binding="{Binding LAST_ATT_DATE}" Header="Last Mod &#x0a;Date" Visibility="Visible"/>

                    <DataGridTextColumn x:Name="CMP_DES" Width="100" Binding="{Binding CMP_DES}" Header="Campgn Name" Visibility="Hidden"/>
                    <DataGridTextColumn x:Name="ADD_DES" Width="150" Binding="{Binding ADD_DES}" Header="Add Name" Visibility="Hidden"/>
                    <DataGridTextColumn  Width="80" Binding="{Binding UPLOADDED_USER}" Header="Added Usr" Visibility="Hidden"/>
                    <DataGridTextColumn  Width="80" Binding="{Binding ASSIGNED_DATE}" Header="Asgnd Date" Visibility="Hidden"/>                    
                    <DataGridTextColumn x:Name="isDeleted" Width="125" Binding="{Binding IS_DELETED}" Header="Last Attended Date" Visibility="Hidden"/>
                    <DataGridTemplateColumn x:Name="clmTransferLead" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical">
                                    <mui:ModernButton x:Name="btnEdit" IconData="{Binding Data, Source={StaticResource ImgEdit}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Edit Record" Click="btnEdit_Click" Visibility="{Binding IS_CLS_STD, Converter={StaticResource IntValueToVisibilityConverter}}"/>
                                    <mui:ModernButton x:Name="btnAddStudent" IconData="{Binding Data, Source={StaticResource ImgAttendance}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Change Lead as Student" Click="btnAddStudent_Click" Visibility="{Binding ISNOT_CLS_STD, Converter={StaticResource IntValueToVisibilityConverter}}" />
                                    <mui:ModernButton x:Name="btnTranferLead" IconData="{Binding Data, Source={StaticResource ImgTransfers}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Tranfer leads to another user" Click="btnTranferLead_Click" />
                                    <mui:ModernButton x:Name="btnRestoreStudent" IconData="{Binding Data, Source={StaticResource ImgRefresh}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Restore delted student" Visibility="{Binding IS_DELETED, Converter={StaticResource IntValueToVisibilityConverter}}" Click="btnRestoreStudent_Click"/>
                                    <mui:ModernButton x:Name="btnDeleteStudent" IconData="{Binding Data, Source={StaticResource ImgDelete}}"  EllipseDiameter="25" EllipseStrokeThickness="1" ToolTip="Delet selected student" Click="btnDeleteStudent_Click" HorizontalAlignment="Center"  Visibility="{Binding IS_DELETED, Converter={StaticResource IntValueToVisibilityConverterZeroValue}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
