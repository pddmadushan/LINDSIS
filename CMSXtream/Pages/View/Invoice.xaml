<UserControl x:Class="CMSXtream.Pages.View.Invoice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CMSXtream.Pages.View"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="txtName" Width="250"/>
        <Button Name="btnPrint" Content="Print Invoice"  Click="btnPrint_Click" Margin="450,0,0,0"  />
        <ScrollViewer Grid.Row="1" Height="650"  x:Name="ScrollInvoice"  >
            <Grid x:Name="print" Margin="40,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="75"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"  Grid.Row="1">
                    <Image Source="/Image/LindsisLogo.png" Width="128" Margin="0,0,0,13"  />
                    <TextBlock TextAlignment="Right" Width="469" > 
                        <Run Text="Lindsis English Institute"  FontSize="10" />
                        <LineBreak/>
                        <Run Text="226, Suwarapola Junction," FontStyle="Italic" FontSize="9"/>
                        <LineBreak/>
                        <Run Text="Piliyandala."  FontStyle="Italic" FontSize="9"/>
                        <LineBreak/>
                        <Run Text="773 814 839, 112 619 536" FontSize="9"/>
                        <LineBreak/>
                        <Run Text="englishclasspiliyandala@gmail.com" FontSize="9" FontStyle="Italic"/>
                        <LineBreak/> 
                        <Run Text="www.englishclass.lk"  FontStyle="Italic" FontSize="9"/>
                    </TextBlock>
                </StackPanel>
                <Line Grid.Row="2"  X1="0" X2="600" Stroke="Black" StrokeThickness="2"  />
                <StackPanel Orientation="Horizontal"   Grid.Row="3" Margin="0,0,0,0" >
                    <TextBlock Text="PAYMENT RECEIPT" VerticalAlignment="Bottom" FontSize="20" FontWeight="Bold" Foreground="#FFC97132"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="0,0,0,0"  >
                    <TextBlock Text="Dear Student," VerticalAlignment="Bottom" FontSize="12" FontWeight="Bold" Foreground="#FF49658E"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="5" Margin="0,0,0,0"  >
                    <TextBlock Text="Thank you for your payment." VerticalAlignment="Bottom" FontSize="12" FontWeight="Bold" Foreground="#FF49658E"/>
                </StackPanel>
                <StackPanel Grid.Row="7" HorizontalAlignment="Stretch"  Margin="0,0,0,0">
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"></RowDefinition>
                            <RowDefinition Height="30"></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtPrintDate"  FontSize="12" FontWeight="Bold" />
                        <TextBlock Text="Student ID / Name :-"  Grid.Row="1"  Grid.Column="0"  FontSize="12" FontWeight="Bold" />
                        <TextBlock x:Name="txtStudent"  Grid.Row="1"  Grid.Column="1"  FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" Width="470"/>
                    </Grid>
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="450"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid  Name="grdMainDetails" AutoGenerateColumns="False"  CanUserSortColumns="False" CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False"  >
                            <DataGrid.Columns  >
                                <DataGridTextColumn Binding="{Binding Path=DES_TEXT}" IsReadOnly="True" Width="250" />
                                <DataGridTextColumn Header="Amount(Rs)" Binding="{Binding Path=DETAILS_AMOUNT }" IsReadOnly="True" Width="150">
                                    <DataGridTextColumn.CellStyle>
                                        <Style>
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.CellStyle>
                                    <DataGridTextColumn.HeaderStyle>
                                        <Style TargetType="{x:Type DataGridColumnHeader}">
                                            <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Background"  Value="Transparent" />
                                        </Style>
                                    </DataGridTextColumn.HeaderStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Row="8" >
                    <Grid Margin="0 20 10 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="250"/>
                        </Grid.ColumnDefinitions>
                        <GroupBox x:Name="grpPayment" >
                            <GroupBox.Header>Payment Details</GroupBox.Header>
                            <DataGrid  Name="grdPayments" AutoGenerateColumns="False"  CanUserSortColumns="False" CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False"  >
                                <DataGrid.Columns  >
                                    <DataGridTextColumn Header=" Date"  Binding="{Binding Path=STD_REC_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="100" >
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Left" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Background"  Value="Transparent" />
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Amount(Rs)" Binding="{Binding Path=PAID_AMOUNT}" IsReadOnly="True" Width="85">
                                        <DataGridTextColumn.CellStyle>
                                            <Style>
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Background"  Value="Transparent" />
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <GroupBox x:Name="grpDelayPay" Grid.Column="2"  >
                            <GroupBox.Header>Delay Fee Details</GroupBox.Header>
                            <DataGrid Name="grdDelayCarges" AutoGenerateColumns="False" CanUserSortColumns="False"  CanUserAddRows="False" RowHeaderWidth="0"  CanUserDeleteRows="False"  >
                                <DataGrid.Columns  >
                                    <DataGridTextColumn Header=" Date"  Binding="{Binding Path=DELAY_DATE, StringFormat={}{0:dd/MM/yyyy}}" IsReadOnly="True" Width="100" >
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Left" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Background"  Value="Transparent" />
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Amount(Rs)" Binding="{Binding Path=DELAY_AMOUNT}" IsReadOnly="True" Width="85">
                                        <DataGridTextColumn.CellStyle>
                                            <Style>
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.CellStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Background"  Value="Transparent" />
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </StackPanel>

                <Line Grid.Row="10"  X1="0" X2="600" Stroke="Black" StrokeThickness="2"  />

                <StackPanel Grid.Row="11" >
                    <TextBlock x:Name="txtSinhalaFont" Margin="0,15,0,10" FontSize="11"></TextBlock>

                    <TextBox x:Name="txtRichBox" Width="590" HorizontalAlignment="Left" VerticalAlignment="Top"  BorderBrush="Transparent" TextWrapping="Wrap" AcceptsReturn="True" Margin="-5,0,0,0" FontSize="11" />

                    <TextBlock x:Name="txtTanks" Text="Thank You" Margin="0,20,0,0"/>
                    <TextBlock x:Name="txtIns" Text="Lindsis English institute."/>
                    <Grid Margin="0,20,0,0" HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom"  Width="570" >
                            <TextBlock Text="This is a computer-generated document. No signature is required." FontSize="10" FontStyle="Italic" FontWeight="Regular"/>
                            <TextBlock Text="                   " FontSize="9" FontStyle="Italic" FontWeight="Light"/>
                            <TextBlock Text="                  " FontSize="9" FontStyle="Italic" FontWeight="Light"/>
                            <TextBlock Text="www.englishclass.lk" FontSize="12" FontStyle="Italic" FontWeight="Bold" TextDecorations="Underline" Foreground="#FFD73131" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
