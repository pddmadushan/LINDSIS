<UserControl x:Class="CMSXtream.Pages.View.Incentive"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
             xmlns:local="clr-namespace:CMSXtream.Control"  
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1000">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/StyleResource/DataGridStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,0" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"  />
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="500" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="10" />
            <RowDefinition Height="30" />
            <RowDefinition Height="20" />
            <RowDefinition Height="40" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ProgressBar x:Name="pgrsBar" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="990" Height="29" Minimum="0" Maximum="100" RenderTransformOrigin="0.5,0.5" Grid.RowSpan="2" Margin="0.4,18.2,0,0" >
            <ProgressBar.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleY="-1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </ProgressBar.RenderTransform>
        </ProgressBar>
        <Label Grid.Row="1" Grid.Column="1" Content="User:" FontSize="20" FontWeight="Bold" Margin="0,0,363,0"   />
        <ComboBox Grid.Row="1" Grid.Column="1"  Name="cmbSearchUser" Style="{DynamicResource ComboBoxFlatStyle}" TabIndex="0" SelectionChanged="cmbSearchUser_SelectionChanged" Margin="163.4,0.4,54.6,10.6"  />
        <Label Grid.Row="3" Grid.Column="1" Content="Select month:" FontSize="20" FontWeight="Bold" Margin="0,0,363,0"   />
        <Label x:Name="lblInfo" Grid.Row="3" Grid.Column="2" Content="" FontSize="15" FontWeight="Bold" Foreground="#FF611306" Margin="0.4,10.2,34.6,0.4"   />

        <DatePicker x:Name="dtpPayMonth" Grid.Row="2" Grid.Column="1" Margin="163.4,9.4,54.6,10.2" local:DatePickerCalendar.IsMonthYear="True" local:DatePickerDateFormat.DateFormat="MMM-yyyy" Text="MMM-yyyy" SelectedDateChanged="dtpPayMonth_SelectedDateChanged" Grid.RowSpan="2" />
        <Rectangle Grid.Row="7" Grid.Column="2" Margin="0,0,10,0" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="1"/>
                    <GradientStop Color="#FF2EFF00"/>
                    <GradientStop Color="#FF19850A" Offset="0.967"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Grid.Row="7" Grid.Column="1" >
            <Rectangle.Fill>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="1"/>
                    <GradientStop Color="#FFF01F1F"/>
                    <GradientStop Color="#FFAA0E0E" Offset="0.997"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Label Grid.Row="7" Grid.Column="1" Content="NO" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"   />
        <Label Grid.Row="7" Grid.Column="2" Content="YES" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"   />
        <Label x:Name="lblIncentiveAmt" Grid.Row="6" Grid.Column="1" Content="" FontSize="20" FontWeight="Bold"  Foreground="White" RenderTransformOrigin="0.5,0.5" Margin="380.4,19.8,9.6,0.2" Grid.RowSpan="2"  />
        <DataGrid Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Name="grdInsentiveInfo" AutoGenerateColumns="False"  CanUserAddRows="False" RowHeaderWidth="0" EnableRowVirtualization = "True"  CanUserDeleteRows="False" Margin="0.4,19.8,299.6,0.2">
            <DataGrid.Columns  >
                <DataGridTextColumn Header="Description" Binding="{Binding Path=INCENTIVE_DES}" IsReadOnly="True"  Width="500"/>
                <DataGridTextColumn Header="Values" Binding="{Binding Path=INCENTIVE_VALUE}"  IsReadOnly="True"  Width="200" >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
